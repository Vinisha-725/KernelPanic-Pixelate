{
  "name": "kernelpanic-pixelate",
  "version": "1.0.0",
  "description": "CleanCity - Environmental Cleanup Tracking System",
  "main": "server/src/server.js",
  "scripts": {
    "start": "node server/src/server.js",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "nodemon server/src/server.js",
    "client": "cd client && npm start",
    "build": "cd client && npm run build",
    "install-client": "cd client && npm install",
    "install-server": "cd server && npm install",
    "install-all": "npm run install-server && npm run install-client"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "mongoose": "^7.5.0",
    "multer": "^1.4.5-lts.1",
    "sharp": "^0.32.6",
    "concurrently": "^8.2.0",
    "nodemon": "^3.0.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "keywords": [
    "environment",
    "cleanup",
    "volunteer",
    "sustainability",
    "ai"
  ],
  "author": "CleanCity Team",
  "license": "MIT"
}
